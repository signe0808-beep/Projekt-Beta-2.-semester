<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Presentation.HeatmapView">
  Welcome to Avalonia!

    <UserControl.Resources>
        <local:BucketToColorConverter x:Key="BucketToColorConverter"/>
    
    </UserControl.Resources>

    <Grid RowDefinitions="*,*,*,*" ColumnDefinitions="*,*,*,*">

        <!-- 4x4 felter -->
        <Border Grid.Row="0" Grid.Column="0" Background="{Binding Buckets[0,0], Converter={StaticResource BucketToColorConverter}}"/>
        <Border Grid.Row="0" Grid.Column="1" Background="{Binding Buckets[0,1], Converter={StaticResource BucketToColorConverter}}"/>
        <Border Grid.Row="0" Grid.Column="2" Background="{Binding Buckets[0,2], Converter={StaticResource BucketToColorConverter}}"/>
        <Border Grid.Row="0" Grid.Column="3" Background="{Binding Buckets[0,3], Converter={StaticResource BucketToColorConverter}}"/>

        <Border Grid.Row="1" Grid.Column="0" Background="{Binding Buckets[1,0], Converter={StaticResource BucketToColorConverter}}"/>
        <Border Grid.Row="1" Grid.Column="1" Background="{Binding Buckets[1,1], Converter={StaticResource BucketToColorConverter}}"/>
        <Border Grid.Row="1" Grid.Column="2" Background="{Binding Buckets[1,2], Converter={StaticResource BucketToColorConverter}}"/>
        <Border Grid.Row="1" Grid.Column="3" Background="{Binding Buckets[1,3], Converter={StaticResource BucketToColorConverter}}"/>

        <Border Grid.Row="2" Grid.Column="0" Background="{Binding Buckets[2,0], Converter={StaticResource BucketToColorConverter}}"/>
        <Border Grid.Row="2" Grid.Column="1" Background="{Binding Buckets[2,1], Converter={StaticResource BucketToColorConverter}}"/>
        <Border Grid.Row="2" Grid.Column="2" Background="{Binding Buckets[2,2], Converter={StaticResource BucketToColorConverter}}"/>
        <Border Grid.Row="2" Grid.Column="3" Background="{Binding Buckets[2,3], Converter={StaticResource BucketToColorConverter}}"/>

        <Border Grid.Row="3" Grid.Column="0" Background="{Binding Buckets[3,0], Converter={StaticResource BucketToColorConverter}}"/>
        <Border Grid.Row="3" Grid.Column="1" Background="{Binding Buckets[3,1], Converter={StaticResource BucketToColorConverter}}"/>
        <Border Grid.Row="3" Grid.Column="2" Background="{Binding Buckets[3,2], Converter={StaticResource BucketToColorConverter}}"/>
        <Border Grid.Row="3" Grid.Column="3" Background="{Binding Buckets[3,3], Converter={StaticResource BucketToColorConverter}}"/>

    </Grid>
</UserControl>