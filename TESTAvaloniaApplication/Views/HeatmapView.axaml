<UserControl 
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:Presentation.Converters"
    xmlns:vm="using:Presentation.ViewModels"
    mc:Ignorable="d"
    d:DesignWidth="800"
    d:DesignHeight="450"
    x:Class="Presentation.HeatmapView"
    x:DataType="vm:HeatmapViewModel">

    <UserControl.Resources>
        <local:BucketToColorConverter x:Key="BucketToColorConverter"/>
    </UserControl.Resources>

    <ItemsControl ItemsSource="{Binding BucketList}">
    <ItemsControl.ItemsPanel>
        <ItemsPanelTemplate>
            <UniformGrid Rows="4" Columns="4"/>
        </ItemsPanelTemplate>
    </ItemsControl.ItemsPanel>

    <ItemsControl.ItemTemplate>
        <DataTemplate x:DataType="x:Double">
            <Border Margin="4"
                    BorderBrush="Black"
                    BorderThickness="1"
                    Background="{Binding Converter={StaticResource BucketToColorConverter}}">

                <TextBlock Text="{Binding StringFormat='{}{0:F0}'}"
                           Foreground="Black"
                           FontSize="24"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>
        </DataTemplate>
    </ItemsControl.ItemTemplate>
</ItemsControl>
</UserControl>